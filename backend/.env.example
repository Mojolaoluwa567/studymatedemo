# Copy this file to .env and fill in real values.
# (Add .env to .gitignore - never commit secrets)

SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-a-different-random-string

# SQLite is used by default (no setup needed) - fine for local dev.
# For production, use a managed Postgres database (Render Postgres,
# Supabase, Neon, Railway Postgres) so data survives redeploys:
# DATABASE_URL=sqlite:///app.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Origin of your deployed frontend (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Required: free key, no credit card needed - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the model used for quiz generation/grading
# GEMINI_MODEL=gemini-2.5-flash

# Optional: SMTP for password reset emails. If left unset, /forgot-password
# returns the reset link directly in the API response (dev mode) so the
# flow still works without an email server.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-email@gmail.com

